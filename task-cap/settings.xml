<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 http://maven.apache.org/xsd/settings-1.0.0.xsd">
  <mirrors>
    <!-- Maven Central for LangChain4j and other public artifacts -->
    <mirror>
      <id>central</id>
      <url>https://repo1.maven.org/maven2</url>
      <mirrorOf>central</mirrorOf>
    </mirror>
  </mirrors>
  <profiles>
    <profile>
      <id>sap-repos</id>
      <repositories>
        <repository>
          <id>sap-releases</id>
          <url>https://int.repositories.cloud.sap/artifactory/build-releases/</url>
          <releases><enabled>true</enabled></releases>
          <snapshots><enabled>false</enabled></snapshots>
        </repository>
        <repository>
          <id>sap-3rd-party</id>
          <url>https://int.repositories.cloud.sap/artifactory/build-releases-3rd-party</url>
          <releases><enabled>true</enabled></releases>
          <snapshots><enabled>false</enabled></snapshots>
        </repository>
      </repositories>
    </profile>
  </profiles>
  <activeProfiles>
    <activeProfile>sap-repos</activeProfile>
  </activeProfiles>
</settings>
